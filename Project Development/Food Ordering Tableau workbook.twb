              <calculation class='tableau' formula='IF [cuisine] = &quot;Biryani&quot;&#13;&#10;OR [cuisine] = &quot;Chinese&quot;&#13;&#10;OR [cuisine] = &quot;South Indian&quot;&#13;&#10;OR [cuisine] = &quot;North Indian&quot;&#13;&#10;OR [cuisine] = &quot;Fast Food&quot;&#13;&#10;OR [cuisine] = &quot;Desserts&quot;&#13;&#10;THEN &quot;True&quot;&#13;&#10;ELSE &quot;False&quot;&#13;&#10;END' />
