        <calculation class='tableau' formula='IF [cuisine] = &quot;Biryani&quot;&#13;&#10;OR [cuisine] = &quot;Chinese&quot;&#13;&#10;OR [cuisine] = &quot;South Indian&quot;&#13;&#10;OR [cuisine] = &quot;North Indian&quot;&#13;&#10;OR [cuisine] = &quot;Fast Food&quot;&#13;&#10;OR [cuisine] = &quot;Desserts&quot;&#13;&#10;THEN &quot;True&quot;&#13;&#10;ELSE &quot;False&quot;&#13;&#10;END' />
      </column>
      <column caption='Meal filter' datatype='string' name='[Calculation_0180617543528450]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [meal_type] = &quot;Breakfast&quot;&#13;&#10;OR [meal_type] = &quot;Lunch&quot;&#13;&#10;OR [meal_type] = &quot;Dinner&quot;&#13;&#10;OR [meal_type] = &quot;Snacks&quot;&#13;&#10;THEN &quot;True&quot;&#13;&#10;ELSE &quot;False&quot;&#13;&#10;END' />
